{payload.filter(p => p.dataKey.endsWith(”_mean”)).map(p => {
const model = p.dataKey.replace(”_mean”, “”);
const row = payload[0]?.payload;
return (
<div key={model} style={{ color: COLORS[model], marginBottom: 3 }}>
<span style={{ fontWeight: 700 }}>{LABELS[model]}</span>
<span style={{ color: “#e2e8f0”, marginLeft: 8 }}>{p.value?.toFixed(1)}%</span>
{row?.[`${model}_min`] != null && (
<span style={{ color: “#64748b”, marginLeft: 8 }}>
[{row[`${model}_min`].toFixed(1)}–{row[`${model}_max`].toFixed(1)}]
</span>
)}
</div>
);
})}
</div>
);
};

