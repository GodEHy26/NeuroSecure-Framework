const LABELS = { robust_cnn: “Robust CNN”, simple_cnn: “Simple CNN”, simple_mlp: “Simple MLP” };

function parseData() {
const rows = RAW.trim().split(”\n”).map(l => {
const [model, epoch, trial, eps, acc] = l.split(”,”);
return { model, epoch: parseInt(epoch), trial: parseInt(trial), eps: parseFloat(eps), acc: parseFloat(acc) };
});
return rows;
}

function aggregate(rows) {
const byModelEps = {};
for (const r of rows) {
const key = `${r.model}__${r.eps}`;
if (!byModelEps[key]) byModelEps[key] = { model: r.model, eps: r.eps, vals: [] };
byModelEps[key].vals.push(r.acc);
}
const result = {};
for (const [key, obj] of Object.entries(byModelEps)) {
const vals = obj.vals;
const mean = vals.reduce((a, b) => a + b, 0) / vals.length;
const std = Math.sqrt(vals.reduce((a, b) => a + (b - mean) ** 2, 0) / vals.length);
if (!result[obj.model]) result[obj.model] = [];
result[obj.model].push({ eps: obj.eps, mean: +mean.toFixed(2), std: +std.toFixed(2), min: +Math.min(…vals).toFixed(2), max: +Math.max(…vals).toFixed(2) });
}
for (const m of MODELS) result[m].sort((a, b) => a.eps - b.eps);
return result;
}

function buildCombinedData(agg) {
const epsSet = [0, …new Set(MODELS.flatMap(m => agg[m].map(d => d.eps)))].sort((a, b) => a - b);
return epsSet.map(eps => {
const row = { eps };
for (const m of MODELS) {
if (eps === 0) {
row[`${m}_mean`] = 100;
row[`${m}_band`] = [100, 100];
row[`${m}_min`] = 100;
row[`${m}_max`] = 100;
} else {
const found = agg[m].find(d => d.eps === eps);
if (found) {
row[`${m}_mean`] = found.mean;
row[`${m}_band`] = [+(found.mean - found.std).toFixed(2), +(found.mean + found.std).toFixed(2)];
row[`${m}_min`] = found.min;
row[`${m}_max`] = found.max;
}
}
}
return row;
});
}

const CustomTooltip = ({ active, payload, label }) => {
if (!active || !payload?.length) return null;
return (
<div style={{ background: “#0f172a”, border: “1px solid #334155”, borderRadius: 8, padding: “10px 14px”, fontSize: 12 }}>
